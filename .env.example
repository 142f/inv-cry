# OKX API credentials.
# Create these in OKX: Profile -> API -> Create V5 API key.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# 1 = demo trading, 0 = live trading.
OKX_SIMULATED=1

# Keep this as 0 until you intentionally want real order submission.
# Even with this set to 1, wrapper methods still default to dry_run=True.
OKX_ENABLE_TRADING=0

# Optional settings.
OKX_DOMAIN=https://www.okx.com
OKX_PROXY=
OKX_USE_SERVER_TIME=0

# Default contract trading settings.
OKX_DEFAULT_SWAP_INST_ID=BTC-USDT-SWAP
OKX_DEFAULT_SWAP_TD_MODE=cross
OKX_DEFAULT_SWAP_LEVERAGE=20
OKX_MAX_LEVERAGE=20
